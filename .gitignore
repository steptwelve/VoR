# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/
ENV/

# Environment variables
.env

# macOS
.DS_Store

# IDE
.vscode/
.idea/
*.swp
*.swo

# YouTube credentials — never commit these
youtube_token.json
youtube_client_secrets.json
claude_creds.json
channel_stats.json

# Built output files — too large for git
output/*.mp4
output/*.png
output/*.jpg

# Background videos — too large for git
backgrounds/*.mp4
backgrounds/*.mov

# .vor-state.json is committed to the repo so rotation state persists
# across GitHub Actions runner instances. Do NOT add it here.

# Test output files (optional - remove if you want to track these)
output/*-a.png
output/*-b.png
output/*-c.png
output/*-d.png
output/*-e.png
output/*-post-preview.txt
output/rr-preview.png

# Recovery Reflections - exclude personal drafts and archives
reflections/queue/
reflections/posted/

vor-daily-meditation-by-sms-*.json
